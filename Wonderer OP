createFeatureButton(tabContents.Combat, "Hitbox Expander", function()
    getgenv().visiblepoints = true
    local char = lp.Character or lp.CharacterAdded:Wait()
    local weapon = char:WaitForChild("Weapon")
    local blade = weapon:WaitForChild("HitParts"):WaitForChild("MainBlade")

    local children = blade:GetChildren()
    for i = #children, 1, -1 do
        if children[i].Name == "DmgPoint" then
            children[i]:Destroy()
        end
    end

    local baseCF = CFrame.new(
        7.82324982, 0.237220764, 0.352325439,
        0.9998101, 0.00494627282, -0.0188489575,
        -0.00540907215, 0.999683261, -0.024581708,
        0.018721398, 0.0246789958, 0.999520183
    )

    local lengthStep, lengthCount = 0.35, 45
    local widthStep, widthCount = 0.3, 3
    local heightStep, heightCount = 0.3, 2
    local lengthCenter = lengthCount / 2
    local visible = visiblepoints

    local lengthOffsets = {}
    for i = 0, lengthCount do
        lengthOffsets[i] = lengthStep * (i - lengthCenter)
    end

    task.spawn(function()
        local batchSize = 50
        local totalCreated = 0
        
        for i = 0, lengthCount do
            local lx = lengthOffsets[i]
            for w = -widthCount, widthCount do
                local wy = widthStep * w
                for h = -heightCount, heightCount do
                    local hz = heightStep * h
                    local att = Instance.new("Attachment")
                    att.Name = "DmgPoint"
                    att.Visible = visible
                    att.CFrame = baseCF * CFrame.new(lx, hz, wy)
                    att.Parent = blade
                    
                    totalCreated = totalCreated + 1
                    if totalCreated % batchSize == 0 then
                        task.wait()
                    end
                end
            end
        end
    end)
end)

