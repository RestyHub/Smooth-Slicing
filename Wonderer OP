local function create(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Corner" then
            obj[k] = v
        end
    end
    if props.Corner then
        local corner = Instance.new("UICorner")
        corner.CornerRadius = props.Corner
        corner.Parent = obj
    end
    return obj
end

