-- INFINITE STAMINA
createToggle(tabContents.Movement, "Infinite Stamina", function(enabled)
    if enabled then
        local function setupStamina(char)
            local staminaValue = nil
            
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("NumberValue") or v:IsA("IntValue") or v:IsA("DoubleConstrainedValue") then
                    local name = v.Name:lower()
                    if name:find("stamina") or name:find("energy") or name:find("endurance") then
                        staminaValue = v
                        break
                    end
                end
            end
            
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            
            if staminaValue then
                activeLoops.stamina = RunService.Heartbeat:Connect(function()
                    if staminaValue and staminaValue.Value < 100 then
                        staminaValue.Value = 100
                    end
                    
                    if humanoid then
                        for _, attr in ipairs({"Stamina", "Energy", "stamina", "energy"}) do
                            if humanoid:GetAttribute(attr) and humanoid:GetAttribute(attr) < 100 then
                                humanoid:SetAttribute(attr, 100)
                            end
                        end
                    end
                end)
                
                staminaValue:GetPropertyChangedSignal("Value"):Connect(function()
                    if staminaValue.Value < 100 then
                        staminaValue.Value = 100
                    end
                end)
            else
                activeLoops.stamina = RunService.Heartbeat:Connect(function()
                    for _, v in pairs(char:GetDescendants()) do
                        if v:IsA("NumberValue") or v:IsA("IntValue") then
                            local name = v.Name:lower()
                            if name:find("stamina") or name:find("energy") or name:find("endurance") then
                                if v.Value < 100 then
                                    v.Value = 100
                                end
                            end
                        end
                    end
                    
                    if humanoid then
                        for _, attr in ipairs({"Stamina", "Energy", "stamina", "energy"}) do
                            if humanoid:GetAttribute(attr) and humanoid:GetAttribute(attr) < 100 then
                                humanoid:SetAttribute(attr, 100)
                            end
                        end
                    end
                end)
            end
        end
        
        if lp.Character then
            setupStamina(lp.Character)
        end
        
        activeLoops.staminaCharAdded = lp.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            setupStamina(char)
        end)
    else
        if activeLoops.stamina then activeLoops.stamina:Disconnect() activeLoops.stamina = nil end
        if activeLoops.staminaCharAdded then activeLoops.staminaCharAdded:Disconnect() activeLoops.staminaCharAdded = nil end
    end
end)

-- Fly
local flyEnabled = false
createToggle(tabContents.Movement, "Fly", function(enabled)
    flyEnabled = enabled
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    if enabled then
        local bg = Instance.new("BodyGyro")
        bg.Name = "FlyGyro"
        bg.Parent = root
        bg.MaxTorque = Vector3.new(400000, 400000, 400000)
        bg.P = 10000
        
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FlyVelocity"
        bv.Parent = root
        bv.MaxForce = Vector3.new(400000, 400000, 400000)
        bv.Velocity = Vector3.zero
        
        activeLoops.fly = RunService.RenderStepped:Connect(function()
            if not flyEnabled then return end
            local cam = workspace.CurrentCamera
            local dir = Vector3.zero
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
            
            bv.Velocity = dir * speedValue
            bg.CFrame = cam.CFrame
        end)
    else
        local bg = root:FindFirstChild("FlyGyro")
        local bv = root:FindFirstChild("FlyVelocity")
        if bg then bg:Destroy() end
        if bv then bv:Destroy() end
        if activeLoops.fly then activeLoops.fly:Disconnect() activeLoops.fly = nil end
    end
end)

