createToggle(tabContents.Visuals, "ESP", function(enabled)
    if enabled then
        local espCache = {}
        
        local function addEsp(player)
            if player == lp then return end
            local char = player.Character
            if not char then return end
            
            if espCache[player] then
                for _, obj in pairs(espCache[player]) do
                    if obj then obj:Destroy() end
                end
            end
            
            espCache[player] = {}
            
            local hl = Instance.new("Highlight")
            hl.Adornee = char
            hl.FillColor = COLORS.esp
            hl.OutlineColor = COLORS.text
            hl.FillTransparency = 0.5
            hl.OutlineTransparency = 0.2
            hl.Parent = char
            table.insert(espCache[player], hl)
            
            local head = char:FindFirstChild("Head")
            if head then
                local bg = Instance.new("BillboardGui")
                bg.Name = "RestyESP"
                bg.Adornee = head
                bg.Size = UDim2.new(0, 100, 0, 40)
                bg.StudsOffset = Vector3.new(0, 2, 0)
                bg.AlwaysOnTop = true
                
                local label = Instance.new("TextLabel")
                label.Parent = bg
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = player.Name
                label.TextColor3 = COLORS.text
                label.Font = Enum.Font.GothamBold
                label.TextSize = 14
                
                bg.Parent = head
                table.insert(espCache[player], bg)
            end
        end
        
        for _, p in ipairs(Players:GetPlayers()) do addEsp(p) end
        
        activeLoops.espPlayerAdded = Players.PlayerAdded:Connect(function(p)
            task.wait(1)
            addEsp(p)
        end)
        
        activeLoops.espCharAdded = {}
        for _, p in ipairs(Players:GetPlayers()) do
            activeLoops.espCharAdded[p] = p.CharacterAdded:Connect(function()
                task.wait(0.5)
                addEsp(p)
            end)
        end
        
        activeLoops.espCleanup = function()
            for _, objs in pairs(espCache) do
                for _, obj in pairs(objs) do
                    if obj then obj:Destroy() end
                end
            end
            espCache = {}
        end
    else
        if activeLoops.espPlayerAdded then activeLoops.espPlayerAdded:Disconnect() end
        if activeLoops.espCharAdded then
            for _, conn in pairs(activeLoops.espCharAdded) do
                conn:Disconnect()
            end
        end
        if activeLoops.espCleanup then activeLoops.espCleanup() end
        activeLoops.espPlayerAdded = nil
        activeLoops.espCharAdded = nil
        activeLoops.espCleanup = nil
    end
end)

