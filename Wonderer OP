    local function makePlayerEntry(player)
        if player == lp then return end
        
        local entry = create("Frame", {
            Parent = scroll,
            Size = UDim2.new(1, -10, 0, 70),
            BackgroundColor3 = COLORS.btn,
            Corner = UDim.new(0, 6)
        })
        
        create("TextLabel", {
            Parent = entry,
            Size = UDim2.new(1, -10, 0, 20),
            Position = UDim2.new(0, 5, 0, 5),
            BackgroundTransparency = 1,
            Text = player.Name,
            TextColor3 = COLORS.text,
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        
        local btns = create("Frame", {
            Parent = entry,
            Size = UDim2.new(1, -10, 0, 35),
            Position = UDim2.new(0, 5, 0, 30),
            BackgroundTransparency = 1
        })
        
        local tp = create("TextButton", {
            Parent = btns,
            Size = UDim2.new(0, 80, 1, 0),
            BackgroundColor3 = COLORS.scroll,
            Text = "TP",
            TextColor3 = COLORS.text,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            Corner = UDim.new(0, 4)
        })
        
        local spec = create("TextButton", {
            Parent = btns,
            Size = UDim2.new(0, 80, 1, 0),
            Position = UDim2.new(0, 85, 0, 0),
            BackgroundColor3 = COLORS.scroll,
            Text = "Spectate",
            TextColor3 = COLORS.text,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            Corner = UDim.new(0, 4)
        })
        
        local twn = create("TextButton", {
            Parent = btns,
            Size = UDim2.new(0, 80, 1, 0),
            Position = UDim2.new(0, 170, 0, 0),
            BackgroundColor3 = COLORS.scroll,
            Text = "Tween",
            TextColor3 = COLORS.text,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            Corner = UDim.new(0, 4)
        })
        
        tp.MouseButton1Click:Connect(function()
            local myChar = lp.Character
            if not myChar then return end
            local myRoot = myChar:FindFirstChild("HumanoidRootPart")
            local targetRoot = getRoot(player)
            if myRoot and targetRoot then
                myRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 0)
            end
        end)
        
        local spectating = false
        local specConn = nil
        spec.MouseButton1Click:Connect(function()
            if spectating then
                spectating = false
                spec.Text = "Spectate"
                if specConn then specConn:Disconnect() end
                local myChar = lp.Character
                if myChar then
                    local hum = myChar:FindFirstChildOfClass("Humanoid")
                    if hum then workspace.CurrentCamera.CameraSubject = hum end
                end
            else
                spectating = true
                spec.Text = "Stop"
                specConn = RunService.RenderStepped:Connect(function()
                    local char = player.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then workspace.CurrentCamera.CameraSubject = hum end
                    end
                end)
            end
        end)
        
        twn.MouseButton1Click:Connect(function()
            if tweenTarget == player then
                tweenTarget = nil
                twn.Text = "Tween"
                twn.BackgroundColor3 = COLORS.scroll
                note.Text = "Select player | Press Q to teleport"
            else
                for _, data in pairs(playerButtons) do
                    data.tween.Text = "Tween"
                    data.tween.BackgroundColor3 = COLORS.scroll
                end
                tweenTarget = player
                twn.Text = "Active"
                twn.BackgroundColor3 = COLORS.accent
                note.Text = "Target: " .. player.Name .. " | Press Q to teleport"
            end
        end)
        
        playerButtons[player] = {entry = entry, tween = twn, spectate = spec}
        scroll.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y + 10)
    end
    
    for _, p in ipairs(Players:GetPlayers()) do makePlayerEntry(p) end
    
    local newPlayerConn = Players.PlayerAdded:Connect(function(p) makePlayerEntry(p) end)
    local removeConn = Players.PlayerRemoving:Connect(function(p)
        if playerButtons[p] then
            playerButtons[p].entry:Destroy()
            playerButtons[p] = nil
        end
        if tweenTarget == p then
            tweenTarget = nil
            note.Text = "Target left"
        end
    end)
    
    local qConn = UserInputService.InputBegan:Connect(function(input, gp)
        if gp or input.KeyCode ~= Enum.KeyCode.Q then return end
        if not tweenTarget then return end
        
        local myChar = lp.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        local targetChar = tweenTarget.Character
        if not targetChar then return end
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        
        if myRoot and targetRoot then
            local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local tween = TweenService:Create(myRoot, tweenInfo, {CFrame = targetRoot.CFrame * CFrame.new(0, 0, 5)})
            tween:Play()
        end
    end)
    
    adminPanel.Destroying:Connect(function()
        if newPlayerConn then newPlayerConn:Disconnect() end
        if removeConn then removeConn:Disconnect() end
        if qConn then qConn:Disconnect() end
        if spectating then
            local myChar = lp.Character
            if myChar then
                local hum = myChar:FindFirstChildOfClass("Humanoid")
                if hum then workspace.CurrentCamera.CameraSubject = hum end
            end
        end
    end)
end)

createFeatureButton(tabContents.Player, "Bring All (Once)", function()
    local myChar = lp.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
