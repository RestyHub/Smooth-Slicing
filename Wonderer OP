                circle.BackgroundColor3 = COLORS.subtext
            end
            callback(enabled)
        end
    end)
    
    parent.CanvasSize = UDim2.new(0, 0, 0, parent.UIListLayout.AbsoluteContentSize.Y + 10)
    return frame
